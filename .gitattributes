# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.rs text eol=lf
*.cpp text eol=crlf
*.h text eol=crlf
*.cs text eol=crlf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=crlf
*.inx text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.dll binary
*.sys binary
*.pdb binary
*.lib binary
*.exp binary
*.obj binary
*.exe binary
*.cer binary
*.pfx binary
*.cat binary

# Agent Artifacts
.agent/* linguist-documentation
.agent/*.md linguist-documentation
.agent/*.MD linguist-documentation
